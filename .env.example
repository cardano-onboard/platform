APP_NAME="Onboard.Ninja"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=onboard
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
PUSHER_APP_CLUSTER=mt1

VITE_APP_NAME="${APP_NAME}"
VITE_VAPOR_ASSET_URL=
VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_HOST="${PUSHER_HOST}"
VITE_PUSHER_PORT="${PUSHER_PORT}"
VITE_PUSHER_SCHEME="${PUSHER_SCHEME}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

# -----------------------------------------------------------------------------
# Sanctum (stateful SPA auth)
# -----------------------------------------------------------------------------
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:3000,127.0.0.1,127.0.0.1:8000,::1

# -----------------------------------------------------------------------------
# Admin seeder (DIY single-admin mode)
# -----------------------------------------------------------------------------
ADMIN_EMAIL=admin@onboard.ninja
ADMIN_PASSWORD=password

# -----------------------------------------------------------------------------
# Cardano / Platform
# -----------------------------------------------------------------------------
POO_PUSH_DELAY=

# Upload limits
UPLOAD_MAX_FILE_SIZE=10485760
UPLOAD_MAX_CODES=10000

# Claim API rate limits (requests per minute)
CLAIM_RATE_PER_IP=60
CLAIM_RATE_PER_CAMPAIGN=120

# -----------------------------------------------------------------------------
# Transaction Backend
# Valid values: null (testing), phyrhose (direct), proxy (SaaS relay)
# Default is 'null' for safe local development — no real transactions.
# Set to 'phyrhose' and fill in credentials below to go live.
# -----------------------------------------------------------------------------
TRANSACTION_BACKEND="null"

# -----------------------------------------------------------------------------
# Phyrhose (transaction backend — required when TRANSACTION_BACKEND=phyrhose)
# Obtain credentials from https://phyrhose.io
# -----------------------------------------------------------------------------
PHYRHOSE_PREPROD_URL=https://testnet.phyrhose.io/
PHYRHOSE_PREPROD_JWT=
PHYRHOSE_PREPROD_ID=
PHYRHOSE_MAINNET_URL=https://api.phyrhose.io/
PHYRHOSE_MAINNET_JWT=
PHYRHOSE_MAINNET_ID=

# -----------------------------------------------------------------------------
# NMKR (NFT minting — optional)
# -----------------------------------------------------------------------------
NMKR_PREPROD_API_URL=https://studio-api.preprod.nmkr.io/v2/
NMKR_PREPROD_API_KEY=
NMKR_MAINNET_API_URL=https://studio-api.nmkr.io/v2/
NMKR_MAINNET_API_KEY=

# -----------------------------------------------------------------------------
# DB-Sync (Cardano chain indexer — optional)
# -----------------------------------------------------------------------------
DBSYNC_PREPROD_HOST=127.0.0.1
DBSYNC_PREPROD_PORT=5432
DBSYNC_PREPROD_DATABASE=cexplorer
DBSYNC_PREPROD_USERNAME=forge
DBSYNC_PREPROD_PASSWORD=

DBSYNC_MAINNET_HOST=127.0.0.1
DBSYNC_MAINNET_PORT=5432
DBSYNC_MAINNET_DATABASE=cexplorer
DBSYNC_MAINNET_USERNAME=forge
DBSYNC_MAINNET_PASSWORD=
